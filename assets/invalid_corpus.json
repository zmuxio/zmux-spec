    {
      "id": "local_provisional_open_cancel_must_not_burn_stream_id",
      "layer": "open_semantics",
      "description": "A provisional local open is cancelled before first-frame commit but still advances the next local stream_id cursor.",
      "input_shape": {
        "local_stream_id": 4,
        "open_stage": "provisional",
        "cancel_before_first_frame_commit": true,
        "next_committed_stream_id": 8
      },
      "expected_result": {
        "scope": "local_send_policy",
