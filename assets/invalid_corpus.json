      "input_shape": {
        "frame_type": "EXT",
        "frame_length_shape": "too_small_for_ext_type_prefix"
      },
      "expected_result": {
        "scope": "session",
        "error": "PROTOCOL"
      }
    },
    {
      "id": "frame_length_smaller_than_stream_id_prefix",
      "layer": "frame",
      "description": "A frame_length remains too small for the actual encoded stream_id prefix after stream_id parsing.",
      "input_shape": {
        "frame_length": 2,
        "stream_id_encoding_length": 4
      },
      "expected_result": {
        "scope": "session",
        "error": "PROTOCOL"
      }
    },
    {
      "id": "frame_ping_with_forbidden_fin_flag",
      "layer": "frame",
      "description": "PING carries a forbidden non-zero flag.",
      "hex": "0a44000102030405060708",
      "expected_result": {
        "scope": "session",
        "error": "PROTOCOL"
      }
    },
    {
      "id": "frame_pong_too_short",
      "layer": "frame",
      "description": "PONG payload is shorter than the required 8-byte token.",
      "input_shape": {
        "frame_type": "PONG",
        "payload_len": 7
      },
      "expected_result": {
        "scope": "session",
        "error": "PROTOCOL"
      }
    },
    {
      "id": "frame_ping_payload_exceeds_local_echoable_limit",
      "layer": "frame",
      "description": "A locally originated PING chooses a payload longer than the smaller of local and peer control-payload limits.",
      "input_shape": {
        "local_max_control_payload_bytes": 4096,
        "peer_max_control_payload_bytes": 16384,
        "attempted_ping_payload_len": 8000
      },
      "expected_result": {
        "scope": "local_send_policy",
        "action": "forbid_send"
      }
    },
    {
      "id": "frame_abort_on_stream_zero",
      "layer": "frame",
