    {
      "id": "rapid_open_abort_churn_without_local_limit",
      "layer": "security",
      "description": "A peer repeatedly opens and immediately aborts streams at abusive rates while the implementation applies no churn limit or disconnect policy.",
      "input_shape": {
        "pattern": "open_then_abort_loop",
        "observed_stream_churn": "above_local_policy_threshold"
      },
      "expected_result": {
        "scope": "local_policy",
        "action": "forbid_unbounded_stream_churn"
