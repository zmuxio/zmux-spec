        "payload_shape": "canonical_varint_plus_trailing_bytes"
      },
      "expected_result": {
        "scope": "session",
        "error": "PROTOCOL"
      }
    },
    {
      "id": "frame_blocked_trailing_garbage",
      "layer": "frame",
      "description": "BLOCKED carries trailing bytes beyond its one canonical blocked_at field.",
      "input_shape": {
        "frame_type": "BLOCKED",
