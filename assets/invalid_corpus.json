    {
      "id": "hidden_control_opened_stream_exceeds_hard_cap_without_shedding",
      "layer": "api_semantics",
      "description": "Hidden control-opened-only nonterminal state exceeds the local hard cap but the implementation neither sheds nor refuses the newest hidden stream.",
      "input_shape": {
        "hidden_control_opened_count": 65,
        "hidden_control_opened_hard_cap": 64,
        "attempted_action": "keep_all_hidden_streams"
      },
      "expected_result": {
        "scope": "local_policy",
        "action": "forbid_unbounded_hidden_state"
      }
