      "input_shape": {
        "frame_type": "ABORT",
        "stream_id": 0
      },
      "expected_result": {
        "scope": "session",
        "error": "PROTOCOL"
      }
    },
    {
      "id": "frame_max_data_trailing_garbage",
      "layer": "frame",
