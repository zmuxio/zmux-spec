        "stopped_directions": 128,
        "late_data_session_aggregate": "above_cap",
        "attempted_action": "continue_buffering_without_bound"
      },
      "expected_result": {
        "scope": "local_policy",
        "action": "forbid_unbounded_late_tail_buffering"
