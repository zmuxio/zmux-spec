          },
          {
            "type": "stream_priority",
            "value": 3
          }
        ]
      },
      "expected_result": {
        "scope": "stream",
        "action": "ignore_entire_update_payload"
      }
    },
    {
      "id": "frame_priority_update_truncated_tlv_header",
