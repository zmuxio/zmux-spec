{
  "schema": "zmux-invalid-corpus-v1",
  "version": 1,
  "cases": [
    {
      "id": "preface_duplicate_setting_id",
      "layer": "preface",
      "description": "A preface settings block repeats the same setting ID.",
      "input_shape": {
        "type": "settings_tlv",
        "setting_ids": [
          6,
          6
        ]
      },
      "expected_result": {
        "scope": "session",
        "error": "PROTOCOL"
      }
    },
    {
      "id": "preface_invalid_role_value",
      "layer": "preface",
      "description": "A peer advertises an unsupported role value.",
      "input_shape": {
        "role": 7
      },
      "expected_result": {
        "scope": "session_establishment",
        "error": "PROTOCOL"
      }
    },
    {
      "id": "preface_auto_equal_nonce_conflict",
      "layer": "preface",
      "description": "Both peers use role=auto with the same tie_breaker_nonce.",
      "input_shape": {
        "local_role": "auto",
        "peer_role": "auto",
        "local_tie_breaker_nonce": 17,
        "peer_tie_breaker_nonce": 17
      },
      "expected_result": {
        "scope": "session_establishment",
        "error": "ROLE_CONFLICT"
      }
    },
    {
      "id": "preface_auto_zero_nonce",
      "layer": "preface",
      "description": "A peer uses role=auto with tie_breaker_nonce = 0.",
      "input_shape": {
        "role": "auto",
        "tie_breaker_nonce": 0
      },
      "expected_result": {
        "scope": "session_establishment",
        "error": "PROTOCOL"
      }
    },
    {
      "id": "preface_frame_payload_limit_too_small",
      "layer": "preface",
      "description": "A peer advertises max_frame_payload below the v1 minimum.",
      "input_shape": {
        "setting": "max_frame_payload",
        "value": 16383
      },
      "expected_result": {
        "scope": "session_establishment",
        "error": "PROTOCOL"
      }
    },
    {
      "id": "preface_control_payload_limit_too_small",
      "layer": "preface",
      "description": "A peer advertises max_control_payload_bytes below the v1 minimum.",
      "input_shape": {
        "setting": "max_control_payload_bytes",
        "value": 4095
      },
      "expected_result": {
        "scope": "session_establishment",
        "error": "PROTOCOL"
      }
    },
    {
      "id": "preface_extension_payload_limit_too_small",
      "layer": "preface",
      "description": "A peer advertises max_extension_payload_bytes below the v1 minimum.",
      "input_shape": {
        "setting": "max_extension_payload_bytes",
        "value": 4095
      },
      "expected_result": {
        "scope": "session_establishment",
        "error": "PROTOCOL"
      }
    },
    {
      "id": "frame_length_too_small",
      "layer": "frame",
      "description": "A frame advertises frame_length smaller than the mandatory code plus shortest stream_id encoding.",
      "input_shape": {
        "frame_length": 1
      },
      "expected_result": {
        "scope": "session",
        "error": "PROTOCOL"
      }
    },
    {
      "id": "frame_ext_payload_underflow",
      "layer": "frame",
